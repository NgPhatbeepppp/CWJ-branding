<!DOCTYPE html>

<html lang="@(ViewContext.RouteData.Values["lang"]?.ToString() ?? "en")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    @* --- 1. SEO AUTOMATION CENTER --- *@
    @{
        // Ưu tiên lấy data từ SeoData, nếu không có mới dùng mặc định
        var seo = ViewBag.SeoData as Cw.Branding.Web.Models.ViewModels.SeoViewModel
        ?? new Cw.Branding.Web.Models.ViewModels.SeoViewModel
        {
            Title = ViewData["Title"]?.ToString() ?? "Charles Wembley",
            Description = ViewData["MetaDescription"]?.ToString() ?? ""
        };
    }
    @* Để partial này lo hết Title, Meta, OG Tags *@
    <partial name="_SeoTags" model="seo" />

    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=2" />

    @* --- 2. FONTS (Đã tinh gọn theo UXD-01) --- *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">

    @* --- 3. STYLES --- *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* CSS riêng cho từng trang (như Swiper cho trang Detail) *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="flex flex-col overflow-x-hidden min-h-screen bg-white text-slate-700 font-body">

    @* 4. Header Partial *@
    <partial name="_Header" />

    @* 5. Main Content Area *@
    @* flex-grow giúp đẩy footer xuống đáy nếu nội dung ngắn *@
    <main role="main" class="flex-grow w-full">
        @RenderBody()
    </main>

    @* 6. Footer Partial *@
    <partial name="_Footer" />

    @* 7. Scripts *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Chừa chỗ cho các page con inject JS riêng (VD: slider, map) *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>