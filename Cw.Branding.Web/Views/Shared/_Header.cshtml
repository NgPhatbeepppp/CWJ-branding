@using Microsoft.AspNetCore.Http
@using System.Globalization
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    // Lấy ngôn ngữ hiện tại chuẩn từ CultureInfo
    var currentLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var isEn = currentLang == "en";
    // Biến này chỉ dùng để ẩn/hiện Spacer (Khoảng trống) ở trang chủ
    bool isHomePage = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
                   && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);

    string GetSwitchLangUrl(string targetLang)
    {
        var routeValues = ViewContext.RouteData.Values;
        var newRouteValues = new RouteValueDictionary(routeValues);
        newRouteValues["lang"] = targetLang;

        // Không cộng thêm Context.Request.QueryString để tránh lặp ?lang=en
        return Url.Action(currentAction, currentController, newRouteValues);
    }
    // Helper: Active State cho Menu
    string IsActive(string controller, string action = null)
    {
        if (string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase))
        {
            if (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            {
                return "text-brand-primary border-b-2 border-brand-primary pb-1";
            }
        }
        return "text-black hover:text-brand-primary";
    }
}

<header class="fixed top-0 left-0 right-0 z-50 bg-transparent backdrop-blur-[2px] transition-all duration-300">

    <div class="w-[92%] max-w-[1600px] h-32 mx-auto flex items-center justify-between px-4 md:px-6">

        <a asp-controller="Home" asp-action="Index" asp-route-lang="en" class="flex-shrink-0">
            <img src="~/images/logo2.png" alt="Charles Wembley" class="h-[126px] w-auto object-contain brightness-0" />
        </a>

        @* UPDATE: 
           1. space-x-12 -> space-x-16 (Tăng khoảng cách menu) 
        *@
        <nav class="hidden lg:flex items-center space-x-16">
            @* UPDATE: 
               2. text-lg -> text-base (Giảm cỡ chữ xuống mức tiêu chuẩn) 
            *@
            <a asp-controller="Home" asp-action="Index" asp-route-lang="@currentLang" class="text-base font-heading font-bold transition-colors uppercase tracking-wide @IsActive("Home")">
                @(isEn ? "Home" : "Trang chủ")
            </a>
            <a asp-controller="About" asp-action="Index" asp-route-lang="@currentLang" class="text-base font-heading font-bold transition-colors uppercase tracking-wide @IsActive("About")">
                @(isEn ? "About Us" : "Về chúng tôi")
            </a>
            <a asp-controller="Medical" asp-action="Index" asp-route-lang="@currentLang" class="text-base font-heading font-bold transition-colors uppercase tracking-wide @IsActive("Medical")">
                @(isEn ? "Medical" : "Y tế")
            </a>
            <a asp-controller="FbSolutions" asp-action="Index" asp-route-lang="@currentLang" class="text-base font-heading font-bold transition-colors uppercase tracking-wide @IsActive("FbSolutions")">
                F&B
            </a>
            <a asp-controller="News" asp-action="Index" asp-route-lang="@currentLang" class="text-base font-heading font-bold transition-colors uppercase tracking-wide @IsActive("News")">
                @(isEn ? "News" : "Tin tức")
            </a>
            <a asp-controller="Contact" asp-action="Index" asp-route-lang="@currentLang" class="text-base font-heading font-bold transition-colors uppercase tracking-wide @IsActive("Contact")">
                @(isEn ? "Contact" : "Liên hệ")
            </a>
        </nav>

        <div class="flex items-center space-x-6">
            @* Cập nhật cỡ chữ cho phần switch ngôn ngữ luôn cho cân đối *@
            <div class="flex items-center border-l border-gray-300 ml-4 pl-4 space-x-3 text-xs font-bold">
                <a href="@GetSwitchLangUrl("en")" class="@(isEn ? "text-brand-primary" : "text-gray-400 hover:text-black") transition-colors">EN</a>
                <span class="text-gray-300">|</span>
                <a href="@GetSwitchLangUrl("vi")" class="@(!isEn ? "text-brand-primary" : "text-gray-400 hover:text-black") transition-colors">VN</a>
            </div>
            @* Search Bar trong Header *@
            <div class="relative hidden xl:block">
                <form action="/@ViewContext.RouteData.Values["lang"]/medical-solutions" method="GET" class="relative">
                    <input type="text" name="searchTerm" placeholder="Search products..."
                           class="w-48 rounded-full border border-slate-300 bg-white/50 py-1.5 pl-4 pr-10 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary transition-all" />
                    <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-brand-primary">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </button>
                </form>
            </div>
            <button type="button" id="mobile-menu-btn" class="lg:hidden p-2 text-black hover:text-brand-primary focus:outline-none">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>

    @* Mobile Menu *@
    <div id="mobile-menu" class="hidden lg:hidden absolute top-32 left-0 w-full bg-white border-b border-gray-200 shadow-lg">
        <div class="px-6 py-4 space-y-4">
            <a asp-controller="Home" asp-action="Index" asp-route-lang="@currentLang" class="block text-base font-heading font-bold uppercase @IsActive("Home")">Home</a>
            <a asp-controller="About" asp-action="Index" asp-route-lang="@currentLang" class="block text-base font-heading font-bold uppercase @IsActive("About")">About Us</a>
            <a asp-controller="Medical" asp-action="Index" asp-route-lang="@currentLang" class="block text-base font-heading font-bold uppercase @IsActive("Medical")">Medical</a>
            <a asp-controller="FbSolutions" asp-action="Index" asp-route-lang="@currentLang" class="block text-base font-heading font-bold uppercase @IsActive("FbSolutions")">F&B</a>
            <a asp-controller="News" asp-action="Index" asp-route-lang="@currentLang" class="block text-base font-heading font-bold uppercase @IsActive("News")">News</a>
            <a asp-controller="Contact" asp-action="Index" asp-route-lang="@currentLang" class="block text-base font-heading font-bold uppercase @IsActive("Contact")">Contact</a>
        </div>
    </div>
</header>

<div class="@(isHomePage ? "hidden" : "h-32")"></div>