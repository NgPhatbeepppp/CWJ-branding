@using System.Globalization
@model Cw.Branding.Web.Models.ViewModels.AboutViewModel
@{
    var currentLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var isEn = currentLang == "en";

    // Giữ nguyên logic Title và MetaDescription như yêu cầu
    ViewData["Title"] = isEn ? (Model.MetaTitle ?? "About Us") : "Về chúng tôi | Charles Wembley";
    ViewData["MetaDescription"] = Model.MetaDescription;
}

@* --- THƯ VIỆN ANIMATION (AOS) --- *@
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Monsieur+La+Doulaise&display=swap" rel="stylesheet">
@* ==========================================
   SECTION 1: ABOUT INTRODUCTION
   ========================================== *@
<section class="relative w-full -mt-24 pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">

    @* Background Layer *@
    <div class="absolute inset-0 z-0">
        <img src="~/images/about-bg-texture.png"
             alt="Background Texture"
             class="w-full h-full object-cover opacity-30" />
    </div>

    @* MAIN CONTAINER *@
    <div class="relative z-10 w-[96%] max-w-screen-3xl mx-auto px-2 md:px-0">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-2 items-center">

            @* --- COL 1: ẢNH --- *@
            <div class="md:col-span-6 flex justify-center md:justify-end relative"
                 data-aos="fade-right">
                <img src="~/images/about-collage.png"
                     alt="Charles Wembley Medical & F&B"
                     class="w-full object-contain drop-shadow-xl transform scale-125 md:translate-x-8 z-10" />
            </div>

            @* --- COL 2: CHỮ --- *@

            <div class="text-center md:text-left md:col-span-6 md:-ml-24 z-20 pl-4"
                 data-aos="fade-left">
                <style>
                    .font-signature-override {
                        font-family: 'Monsieur La Doulaise', cursive !important;
                    }
                </style>
                @* TIÊU ĐỀ *@
                <h1 class="flex flex-col md:flex-row items-center md:items-baseline gap-x-4 mb-6">
                    <span class="text-2xl md:text-5xl lg:text-5xl text-slate-900 font-heading font-light tracking-wide whitespace-nowrap ">
                        @(isEn ? "About" : "Về")
                    </span>
                    <span class="font-signature-override text-3xl md:text-7xl lg:text-7xl whitespace-nowrap leading-none mt-2 md:mt-0">
                        Charles Wembley
                    </span>
                </h1>

                @* Nội dung *@
                <div class="text-slate-800 text-base md:text-lg lg:text-xl font-narrative tracking-wide opacity-90 space-y-6 pr-4 md:pr-12 max-w-[800px]"
                     style="line-height: 1.6;"
                     data-aos="fade-up" data-aos-delay="200">
                    <p class="font-narrative">
                        @(isEn
                                                ? "Charles Wembley is a global leader in cutting-edge medical solutions and premium food & beverage (F&B) systems. The company is dedicated to advancing healthcare with state-of-the-art technology, while enriching culinary experiences worldwide through innovative F&B offerings."
                                                : "Charles Wembley là đơn vị dẫn đầu toàn cầu trong các giải pháp y tế tiên tiến và hệ thống thực phẩm & đồ uống (F&B) cao cấp. Chúng tôi cam kết thúc đẩy nền y tế phát triển bằng công nghệ hiện đại, đồng thời nâng tầm trải nghiệm ẩm thực toàn thế giới thông qua các giải pháp F&B sáng tạo.")
                    </p>
                </div>
            </div>
        </div>
    </div>

</section>

@* ==========================================
   SECTION TRANSITION
   ========================================== *@
<div class="w-full h-[245px] relative overflow-hidden" data-aos="fade-in">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat bg-fixed"
         style="background-image: url('/images/fnb-hero.png');">
        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-t from-white to-transparent"></div>
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-b from-white to-transparent"></div>
        <div class="absolute inset-0 bg-black/10"></div>
    </div>
</div>

@* ==========================================
   SECTION 2: OUR STORY
   ========================================== *@
<section id="our-story" class="relative w-full py-16 md:py-24 bg-[#FDFBF7] overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="~/images/about-bg-texture.png" alt="Texture" class="w-full h-full object-cover opacity-30" />
    </div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-4xl md:text-5xl text-[#002143] font-narrative mb-6 tracking-wide"
                data-aos="fade-up">
                @(isEn ? "Our Story" : "Câu chuyện của chúng tôi")
            </h2>

            <div class="w-[200px] md:w-[600px] h-[2px] bg-[#004F9F] mx-auto mb-10"
                 data-aos="zoom-in" data-aos-delay="200"></div>

            <div class="[&_p]:font-narrative font-narrative text-slate-700 text-xl md:text-2xl leading-relaxed space-y-6 text-center max-w-4xl mx-auto">
                <p data-aos="fade-up" data-aos-delay="300">
                    @(isEn
                                        ? "Driven by a pioneering spirit, we at Charles Wembley (Tan Long) have grown to become one of the largest and most trusted medical equipment suppliers in Vietnam."
                                        : "Với tinh thần tiên phong, chúng tôi tại Charles Wembley (Tân Long) đã phát triển để trở thành một trong những nhà cung cấp thiết bị y tế lớn nhất và đáng tin cậy nhất tại Việt Nam.")
                </p>
                <p data-aos="fade-up" data-aos-delay="400">
                    @(isEn
                                        ? "With an extensive network across Vietnam and Cambodia, we specialize in essential solutions for Surgery, ICU & Emergency, Anesthesia, Neonatal, Urology, and Ophthalmology. Our mission is to deliver optimal solutions that perfectly balance quality and cost, backed by our deep industry experience."
                                        : "Với mạng lưới rộng khắp Việt Nam và Campuchia, chúng tôi chuyên cung cấp các giải pháp thiết yếu cho Phẫu thuật, Hồi sức cấp cứu (ICU), Gây mê, Sơ sinh, Tiết niệu và Nhãn khoa. Sứ mệnh của chúng tôi là mang đến những giải pháp tối ưu, cân bằng hoàn hảo giữa chất lượng và chi phí, dựa trên kinh nghiệm chuyên sâu trong ngành.")
                </p>
                <p data-aos="fade-up" data-aos-delay="500">
                    @(isEn
                                        ? "We are proud to be the official distributor for world-leading brands like Masimo, Johnson & Johnson, Seca, Fisher & Paykel, and Reichert. Above all, we are committed to being your trusted companion on every step of your journey."
                                        : "Chúng tôi tự hào là nhà phân phối chính thức cho các thương hiệu hàng đầu thế giới như Masimo, Johnson & Johnson, Seca, Fisher & Paykel và Reichert. Trên tất cả, chúng tôi cam kết là người đồng hành đáng tin cậy trên mọi bước đường của bạn.")
                </p>
            </div>
        </div>
    </div>
</section>

@* ==========================================
   SECTION 3: JOURNEY - VISION - VALUES
   ========================================== *@
<section id="vision-values" class="w-full py-16 md:py-24 bg-white">
    <div class="w-[75%] mx-auto max-w-none">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-32 lg:gap-32 items-start">

            @* --- COL 1: VIDEO (Sticky) --- *@
            <div class="relative w-full rounded-sm overflow-hidden shadow-2xl aspect-[2/3] lg:sticky lg:top-24 pointer-events-none"
                 data-aos="fade-in" data-aos-duration="2000">
                <video autoplay loop muted playsinline class="w-full h-full object-cover" poster="/images/about/journey-poster.jpg">
                    <source src="~/videos/cw-journey.mp4" type="video/mp4">
                </video>
            </div>

            @* --- COL 2: RIGHT CONTENT --- *@
            <div class="flex flex-col justify-between min-h-[1500px] py-10 [&_p]:font-['Montserrat']">
                <div data-aos="fade-left">
                    <h2 class="text-[#004F9F] font-heading font-bold text-3xl md:text-4xl uppercase tracking-wide mb-8">
                        @(isEn ? "Vision & Core Value" : "Tầm nhìn & Giá trị cốt lõi")
                    </h2>
                    <img src="~/images/vision-bg.png" alt="Charles Wembley Office" class="w-[85%] h-auto object-cover rounded-sm shadow-md" />
                </div>

                <div class="py-12 border-b border-slate-100" data-aos="fade-up">
                    <h3 class="text-[#004F9F] font-heading font-bold text-2xl uppercase mb-6">
                        @(isEn ? "Our Vision" : "Tầm nhìn của chúng tôi")
                    </h3>
                    <p class="text-slate-800 leading-loose font-body text-lg md:text-xl">
                        @(isEn
                                                ? "We aspire to set the benchmark for trustworthy Medical and F&B solutions—combining rigor, design, and service to help organizations work safer, faster, and smarter. By uniting proven expertise with practical innovation, we enable our partners to deliver better experiences and measurable results."
                                                : "Chúng tôi mong muốn thiết lập tiêu chuẩn cho các giải pháp Y tế và F&B đáng tin cậy — kết hợp giữa sự khắt khe, thiết kế và dịch vụ để giúp các tổ chức làm việc an toàn hơn, nhanh hơn và thông minh hơn. Bằng cách kết hợp chuyên môn vững chắc với những cải tiến thiết thực, chúng tôi giúp các đối tác mang lại trải nghiệm tốt hơn và kết quả rõ rệt.")
                    </p>
                </div>

                <div>
                    <h3 class="text-[#004F9F] font-heading font-bold text-2xl uppercase mb-12 mt-6 " data-aos="fade-up">
                        @(isEn ? "Our Values" : "Giá trị của chúng tôi")
                    </h3>

                    <div class="space-y-12">
                        <div class="group" data-aos="fade-up">
                            <h4 class="text-[#002143] font-bold text-xl mb-2 group-hover:text-[#004F9F] transition-colors">@(isEn ? "Integrity" : "Chính trực")</h4>
                            <p class="text-slate-600 text-base md:text-lg leading-relaxed">
                                @(isEn ? "We speak plainly, deliver exactly what we promise, and back decisions with evidence." : "Chúng tôi nói thẳng, làm đúng những gì đã cam kết và đưa ra quyết định dựa trên minh chứng rõ ràng.")
                            </p>
                        </div>

                        <div class="group" data-aos="fade-up">
                            <h4 class="text-[#002143] font-bold text-xl mb-2 group-hover:text-[#004F9F] transition-colors">@(isEn ? "Safety & Compliance" : "An toàn & Tuân thủ")</h4>
                            <p class="text-slate-600 text-base md:text-lg leading-relaxed">
                                @(isEn ? "People come first. We follow clinical and industry standards to protect patients, guests, and teams." : "Con người là trên hết. Chúng tôi tuân thủ các tiêu chuẩn lâm sàng và ngành để bảo vệ bệnh nhân, khách hàng và đội ngũ.")
                            </p>
                        </div>

                        <div class="group" data-aos="fade-up">
                            <h4 class="text-[#002143] font-bold text-xl mb-2 group-hover:text-[#004F9F] transition-colors">@(isEn ? "Practical Innovation" : "Cải tiến thiết thực")</h4>
                            <p class="text-slate-600 text-base md:text-lg leading-relaxed">
                                @(isEn ? "We build useful improvements that scale—never complexity for its own sake." : "Chúng tôi xây dựng những cải tiến hữu ích có khả năng mở rộng, không bao giờ làm phức tạp hóa vấn đề một cách vô ích.")
                            </p>
                        </div>

                        <div class="group" data-aos="fade-up">
                            <h4 class="text-[#002143] font-bold text-xl mb-2 group-hover:text-[#004F9F] transition-colors">@(isEn ? "Reliability & Accountability" : "Tin cậy & Trách nhiệm")</h4>
                            <p class="text-slate-600 text-base md:text-lg leading-relaxed">
                                @(isEn ? "Clear commitments, on-time handoffs, and ownership of outcomes." : "Cam kết rõ ràng, bàn giao đúng hạn và luôn chịu trách nhiệm về kết quả đạt được.")
                            </p>
                        </div>

                        <div class="group" data-aos="fade-up">
                            <h4 class="text-[#002143] font-bold text-xl mb-2 group-hover:text-[#004F9F] transition-colors">@(isEn ? "Partnership Mindset" : "Tư duy cộng tác")</h4>
                            <p class="text-slate-600 text-base md:text-lg leading-relaxed">
                                @(isEn ? "We succeed with our clients and suppliers, not just for them—through transparency and respect." : "Chúng tôi thành công cùng với khách hàng và nhà cung cấp, chứ không chỉ cho họ — thông qua sự minh bạch và tôn trọng lẫn nhau.")
                            </p>
                        </div>

                        <div class="group" data-aos="fade-up">
                            <h4 class="text-[#002143] font-bold text-xl mb-2 group-hover:text-[#004F9F] transition-colors">@(isEn ? "Continuous Improvement" : "Cải tiến không ngừng")</h4>
                            <p class="text-slate-600 text-base md:text-lg leading-relaxed">
                                @(isEn ? "Small, repeatable upgrades that compound over time." : "Những nâng cấp nhỏ, có tính lặp lại thường xuyên để tạo nên giá trị lớn theo thời gian.")
                            </p>
                        </div>
                    </div>
                </div>
                <div class="h-20"></div>
            </div>
        </div>
    </div>
</section>

@* ==========================================
   SECTION 4: LEADERSHIP SLIDER
   ========================================== *@
<section id="leadership"
         class="relative z-20 -mb-[90px] bg-[#528AC4] text-white py-20 md:py-28 rounded-br-[80px] md:rounded-br-[40px] overflow-hidden"
         data-aos="fade-up">

    <div class="container mx-auto px-4 max-w-[1500px]">
        <div class="text-center mb-16 md:mb-20">
            <h2 class="font-heading text-white font-bold text-2xl md:text-4xl uppercase tracking-[0.1em]"
                data-aos="fade-up" data-aos-delay="200">
                @(isEn ? "Guided by Experience and Vision" : "Dẫn dắt bởi Kinh nghiệm và Tầm nhìn")
            </h2>
        </div>

        <div class="swiper leadership-swiper relative" data-aos="fade-in" data-aos-delay="400">
            <div class="swiper-wrapper">

                @* SLIDE 1 *@
                <div class="swiper-slide">
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-18 items-center">
                        <div class="md:col-span-5 md:pl-16 border-l-2 border-white/30 h-full flex flex-col justify-center text-left">
                            <blockquote class="font-['Montaga'] text-lg md:text-2xl leading-relaxed mb-7 italic opacity-90">
                                "@(isEn
                                                                ? "Charles Wembley is a leader in providing cutting-edge medical and food & beverage solutions, dedicated to advancing healthcare and enriching culinary experiences around the world." 
                                                                        : "Charles Wembley dẫn đầu trong việc cung cấp các giải pháp y tế và thực phẩm & đồ uống tiên tiến, cam kết thúc đẩy nền y tế phát triển và làm phong phú thêm trải nghiệm ẩm thực trên toàn thế giới.")"
                            </blockquote>
                            <div>
                                <h4 class="font-heading font-bold text-xl uppercase tracking-wide">Mr. Charles Wembley</h4>
                                <p class="text-blue-100 text-sm uppercase tracking-wider mt-1">@(isEn ? "Founder & CEO" : "Nhà sáng lập & CEO")</p>
                            </div>
                        </div>

                        <div class="md:col-span-7 flex justify-center md:justify-end">
                            <div class="w-full max-w-lg aspect-square bg-white/10 backdrop-blur-sm p-4 rounded-sm">
                                <img src="~/images/manager-simple.jpg"
                                     alt="Mr. Charles Wembley"
                                     class="w-full h-full object-cover shadow-2xl  transition-all duration-500" />
                            </div>
                        </div>
                    </div>
                </div>

                @* SLIDE 2 *@
                <div class="swiper-slide">
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-18 items-center">
                        <div class="md:col-span-5 md:pl-16 border-l-2 border-white/30 h-full flex flex-col justify-center text-left">
                            <blockquote class="font-['Montaga'] text-lg md:text-2xl leading-relaxed mb-7 italic opacity-90">
                                "@(isEn
                                                                ? "Our technology vision is simple: Practical innovation that solves real-world problems for hospitals and businesses across Southeast Asia."
                                                                : "Tầm nhìn công nghệ của chúng tôi rất đơn giản: Những cải tiến thiết thực giúp giải quyết các vấn đề thực tế cho các bệnh viện và doanh nghiệp trên khắp Đông Nam Á.")"
                            </blockquote>
                            <div>
                                <h4 class="font-heading font-bold text-xl uppercase tracking-wide">Ms. Sarah Nguyen</h4>
                                <p class="text-blue-100 text-sm uppercase tracking-wider mt-1">@(isEn ? "Chief Technology Officer" : "Giám đốc Công nghệ")</p>
                            </div>
                        </div>
                        <div class="md:col-span-7 flex justify-center md:justify-end">
                            <div class="w-full max-w-lg aspect-square bg-white/20 backdrop-blur-sm p-4 rounded-sm">
                                <img src="~/images/manager-simbple2.jpg"
                                     alt="Ms. Sarah Nguyen"
                                     class="w-full h-full object-cover shadow-2xl transition-all duration-500" />
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            @* NAVIGATION ARROWS *@
            <div class="flex gap-4 mt-10 md:mt-0 md:absolute md:bottom-0 md:left-8 z-30">
                <button class="swiper-button-prev-custom group">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10 text-white/70 group-hover:text-white transition-colors">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                    </svg>
                </button>
                <button class="swiper-button-next-custom group">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10 text-white/70 group-hover:text-white transition-colors">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            AOS.init({
                duration: 1500,
                easing: 'ease-out-cubic',
                once: true,
                offset: 250
            });

            var leaderSwiper = new Swiper(".leadership-swiper", {
                slidesPerView: 1,
                spaceBetween: 50,
                speed: 800,
                loop: true,
                effect: 'fade',
                fadeEffect: { crossFade: true },
                navigation: {
                    nextEl: ".swiper-button-next-custom",
                    prevEl: ".swiper-button-prev-custom",
                },
                autoplay: {
                    delay: 6000,
                    disableOnInteraction: false,
                }
            });
        });
    </script>
}