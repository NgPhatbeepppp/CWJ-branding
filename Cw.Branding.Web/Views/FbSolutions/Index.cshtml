@model Cw.Branding.Web.Models.ViewModels.FbSolutionViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Title;
}

@* --- THƯ VIỆN AOS  --- *@
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

@* --- F&B SOLUTIONS SECTION (Updated Design) --- *@
<section class="relative w-full h-[900px] flex items-center justify-center bg-cover bg-center bg-no-repeat overflow-hidden"
         style="background-image: url('@Model.BackgroundImagePath');">

    @* Overlay *@
    <div class="absolute inset-0 bg-black/20 z-0"></div>

    <div class="w-full px-4 md:px-8 relative z-10 flex justify-center">

        @* Border Box: Xuất hiện trước *@
        <div class="border-[3px] border-[#FAF0BF] p-10 md:p-16 w-full max-w-7xl text-center backdrop-blur-sm mx-auto"
             data-aos="fade-in"
             data-aos-duration="1500">

            @* 1. Title: Trượt lên *@
            <h2 class="font-heading font-bold text-4xl md:text-5xl text-white uppercase mb-8 tracking-wider"
                data-aos="fade-up"
                data-aos-delay="200">
                @Html.Raw(Model.Title)
            </h2>

            @* 2. Description: Trượt lên sau Title *@
            <p class="font-source-serif font-bold italic text-xl md:text-2xl text-white mb-10 w-full"
               style="line-height: 28px; letter-spacing: 0.03em;"
               data-aos="fade-up"
               data-aos-delay="400">
                @Html.Raw(Model.Description)
            </p>

            @* 3. CTA Button: Trượt lên sau cùng *@
            <div data-aos="fade-up" data-aos-delay="600">
                <a href="@Model.TargetUrl" target="_blank" rel="noopener noreferrer"
                   class="inline-block bg-[#F9EDB3] hover:bg-yellow-400 text-[#5c563d]
                          font-heading font-bold text-lg px-10 py-3 rounded-full
                          transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1">
                    @Model.ButtonText
                </a>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            AOS.init({
                duration: 1500,       
                easing: 'ease-out-cubic', 
                once: true,           
                offset: 100           
            });
        });
    </script>
}