@using System.Globalization
@model Cw.Branding.Web.Models.Entities.Product
@{
    var currentLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var isEn = currentLang == "en";
    var name = isEn ? Model.NameEn : Model.NameVi;
    var categoryName = isEn ? Model.Category.NameEn : Model.Category.NameVi;

    // Dữ liệu nội dung chính
    var dbDescription = isEn ? Model.DescriptionEn : Model.DescriptionVi;
    var shortDesc = isEn ? Model.ShortDescriptionEn : Model.ShortDescriptionVi;
    var mainContent = !string.IsNullOrEmpty(dbDescription) ? dbDescription : shortDesc;

    // Dữ liệu thông số kỹ thuật (Rich Text)
    var techSpecs = isEn ? Model.TechnicalSpecsEn : Model.TechnicalSpecsVi;

    var mainImage = Model.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault()?.FilePath
                    ?? "https://via.placeholder.com/500x500?text=No+Image";

    ViewData["Title"] = name;

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

}

@* --- BANNER --- *@
<div class="relative h-[200px] w-full overflow-hidden bg-slate-900">
    <img src="/images/medical-bg-4.jpg" alt="Banner" class="h-full w-full object-cover opacity-60" />
    <div class="absolute inset-0 flex items-center justify-center">
        <h1 class="font-heading text-3xl font-bold uppercase tracking-widest text-white md:text-4xl drop-shadow-md">
            @categoryName
        </h1>
    </div>
</div>

@* --- BREADCRUMB --- *@
<div class="border-b border-slate-200 bg-white">
    <div class="section-container py-3">
        <div class="mb-2">
            <a href="javascript:history.back()" class="inline-flex items-center text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-brand-primary transition-colors">
                <svg class="mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                @(isEn ? "Back" : "Quay lại")
            </a>
        </div>
        <nav class="flex text-sm text-slate-500" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li><a href="/@currentLang" class="hover:text-brand-primary">Home</a></li>
                <li>/</li>
                <li><a href="/@currentLang/@(isEn ? "medical-solutions" : "giai-phap-y-te")" class="hover:text-brand-primary">@(isEn ? "Medical" : "Y tế")</a></li>
                <li>/</li>
                <li class="font-medium text-brand-primary">@name</li>
                <li aria-current="page">
                    <span class="font-medium text-brand-primary line-clamp-1 max-w-[200px]">@name</span>
                </li>
            </ol>
        </nav>
    </div>
</div>

<div class="section-container py-12 md:py-16">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
        <div class="lg:col-span-5 flex flex-col gap-4">
            @* --- 1. ẢNH LỚN (MAIN DISPLAY) --- *@
            <div class="relative group overflow-hidden rounded-lg border border-slate-100 bg-white p-4 shadow-sm aspect-square flex items-center justify-center">
                @{
                    var allImages = Model.Images?.OrderBy(i => i.DisplayOrder).ToList() ?? new List<Cw.Branding.Web.Models.Entities.ProductImage>();
                    var displayImage = allImages.FirstOrDefault(i => i.IsMain)?.FilePath ?? allImages.FirstOrDefault()?.FilePath ?? "https://via.placeholder.com/500x500?text=No+Image";
                }
                <img id="main-product-image" src="@displayImage" alt="@name" class="h-full w-full object-contain transition-opacity duration-300" />

                @* Mũi tên điều hướng trên ảnh lớn (Optional) *@
                <button onclick="prevImage()" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 p-2 rounded-full shadow-md opacity-0 group-hover:opacity-100 transition-opacity">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
                <button onclick="nextImage()" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 p-2 rounded-full shadow-md opacity-0 group-hover:opacity-100 transition-opacity">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
            </div>

            @* --- 2. THUMBNAIL SLIDER (SWIPER) --- *@
            @if (allImages.Count > 1)
            {
                <div class="relative px-8">
                    @* Thêm padding để lộ mũi tên *@
                    <div class="swiper thumbSwiper overflow-hidden">
                        <div class="swiper-wrapper">
                            @for (int i = 0; i < allImages.Count; i++)
                            {
                                <div class="swiper-slide cursor-pointer">
                                    <div class="thumbnail-item rounded border-2 @(allImages[i].FilePath == displayImage ? "border-brand-primary" : "border-transparent") transition-all aspect-square bg-white p-1 overflow-hidden"
                                         onclick="switchProductImage(this, '@allImages[i].FilePath', @i)">
                                        <img src="@allImages[i].FilePath" alt="thumbnail" class="h-full w-full object-cover" />
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    @* Nút điều hướng của Swiper *@
                    <div class="swiper-button-prev !text-brand-primary !after:text-sm !-left-2"></div>
                    <div class="swiper-button-next !text-brand-primary !after:text-sm !-right-2"></div>
                </div>
            }

            @* --- 3. THÔNG SỐ KỸ THUẬT (GIỮ NGUYÊN) --- *@
            <div class="bg-blue-50/80 p-6 rounded-sm border-l-4 border-brand-primary shadow-sm mt-4" data-aos="fade-up">
                <h3 class="mb-4 font-heading text-lg font-bold uppercase text-brand-primary flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.5l5 5v2m0 0h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5"></path></svg>
                    @(isEn ? "TECHNICAL INFORMATION" : "THÔNG SỐ KỸ THUẬT")
                </h3>
                <div class="font-body text-sm text-slate-700 prose prose-sm max-w-none">
                    @if (!string.IsNullOrEmpty(techSpecs))
                    {
                        @Html.Raw(techSpecs)
                    }
                    else
                    {

                        <p class="italic">@(isEn ? "Updating..." : "Đang cập nhật...")</p>
                    }
                </div>
            </div>
        </div>

        @* --- CỘT PHẢI: THÔNG TIN CHI TIẾT --- *@
        <div class="lg:col-span-7 lg:border-l lg:border-slate-200 lg:pl-20">
            <div class="mb-2 text-right">
                @* ĐỔ TÊN HÃNG THẬT *@
                <span class="font-heading text-xl font-bold text-slate-900 uppercase">@(Model.Brand?.Name ?? "")</span>
            </div>

            <div class="mb-6 text-right border-b border-slate-200 pb-6">
                <h1 class="font-heading text-4xl font-extrabold uppercase text-slate-900 lg:text-5xl leading-tight">
                    @name
                </h1>
                <p class="mt-2 text-lg text-slate-500 font-light">
                    Mã sản phẩm: <span class="font-medium">@Model.Code</span>
                </p>
            </div>

            <h2 class="mb-4 font-heading text-lg font-bold uppercase text-brand-primary">
                @(isEn ? "PRODUCT INFORMATION" : "THÔNG TIN SẢN PHẨM")
            </h2>

            <div class="prose prose-slate max-w-none font-body text-slate-600 leading-relaxed mb-8">
                @if (!string.IsNullOrEmpty(mainContent))
                {
                    @Html.Raw(mainContent)
                }
                else
                {
                    <p class="text-slate-400 italic">@(isEn ? "Content is being updated..." : "Nội dung đang được cập nhật...")</p>
                }
            </div>

            @* --- NÚT TẢI PDF --- *@
            @if (!string.IsNullOrEmpty(Model.DatasheetPath))
            {
                <div class="mt-8">
                    <a href="@Model.DatasheetPath" target="_blank" class="inline-flex items-center justify-center bg-brand-primary px-8 py-3 text-base font-bold text-white shadow-md transition-all hover:bg-blue-700 hover:shadow-lg rounded-sm uppercase tracking-wide w-full sm:w-auto">
                        <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.5l5 5v2m0 0h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5"></path></svg>
                        @(isEn ? "Download PDF Datasheet" : "Tải tài liệu PDF")
                    </a>
                </div>
            }
        </div>
    </div>
</div>
<script>
    let currentIndex = 0;
    const images = @Html.Raw(Json.Serialize(allImages.Select(i => i.FilePath)));

    // Khởi tạo Swiper cho thumbnails
    const swiper = new Swiper(".thumbSwiper", {
        slidesPerView: 4,
        spaceBetween: 10,
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
        breakpoints: {
            640: { slidesPerView: 5 },
        }
    });

    function switchProductImage(element, src, index) {
        currentIndex = index;
        const mainImg = document.getElementById('main-product-image');
        mainImg.style.opacity = '0.3';

        setTimeout(() => {
            mainImg.src = src;
            mainImg.style.opacity = '1';

            // Update border
            document.querySelectorAll('.thumbnail-item').forEach(item => {
                item.classList.remove('border-brand-primary');
                item.classList.add('border-transparent');
            });
            element.classList.remove('border-transparent');
            element.classList.add('border-brand-primary');
        }, 150);
    }

    function nextImage() {
        currentIndex = (currentIndex + 1) % images.length;
        updateMainImageFromIndex();
    }

    function prevImage() {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        updateMainImageFromIndex();
    }

    function updateMainImageFromIndex() {
        const targetThumb = document.querySelectorAll('.thumbnail-item')[currentIndex];
        if (targetThumb) targetThumb.click();
        swiper.slideTo(currentIndex);
    }
</script>                                                                                    