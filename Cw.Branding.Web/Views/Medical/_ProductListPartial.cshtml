@using Cw.Branding.Web.Models.Entities
@model IEnumerable<Product>
@{
    var lang = Context.GetRouteValue("lang")?.ToString() ?? "en";
}

<div class="section-container">
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            @foreach (var item in Model)
            {
                var firstImage = item.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault();
                var imgSrc = (firstImage != null) ? firstImage.FilePath : "https://via.placeholder.com/400x400?text=No+Image";

                // Chọn tên theo ngôn ngữ
                var displayName = lang == "vi" ? item.NameVi : item.NameEn;
                var displayDesc = lang == "vi" ? item.ShortDescriptionVi : item.ShortDescriptionEn;
                var displaySlug = lang == "vi" ? item.SlugVi : item.SlugEn;

                <div class="group relative flex flex-col overflow-hidden rounded-lg bg-white shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-hover border border-slate-100 h-full">

                    @* 1. Vùng chứa ảnh: Cố định tỉ lệ 1:1 *@
                    <div class="relative aspect-square w-full overflow-hidden bg-white p-6 flex items-center justify-center">
                        <img src="@imgSrc"
                             alt="@displayName"
                             class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105" />

                        @* Overlay nhẹ khi hover *@
                        <div class="absolute inset-0 bg-brand-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    </div>

                    @* 2. Vùng thông tin: Dùng flex-1 để lấp đầy card *@
                    <div class="flex flex-1 flex-col bg-blue-400 px-5 py-5 text-white">
                        <h3 class="mb-2 font-heading text-base text-white font-bold uppercase tracking-wide line-clamp-2 min-h-[3rem]">
                            @displayName
                        </h3>

                        @if (!string.IsNullOrEmpty(displayDesc))
                        {
                            <p class="font-body text-xs font-light leading-relaxed text-blue-100/90 line-clamp-3">
                                @displayDesc
                            </p>
                        }

                        @* Nút giả để tăng tính dẫn dắt (UX 3-click) *@
                        <div class="mt-auto pt-4 flex items-center text-[10px] font-bold tracking-widest uppercase text-yellow-400 opacity-0 group-hover:opacity-100 transition-all transform translate-y-2 group-hover:translate-y-0">
                            View Details <i class="fas fa-arrow-right ml-2"></i>
                        </div>
                    </div>

                    @* Link bao phủ toàn bộ card *@
                    <a href="/@lang/medical/product/@displaySlug" class="absolute inset-0 z-10" aria-label="View @displayName"></a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="py-20 text-center text-slate-400">
            <i class="fas fa-box-open text-4xl mb-3"></i>
            <p>No products found in this category.</p>
        </div>
    }
</div>