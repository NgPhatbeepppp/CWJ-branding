@using Cw.Branding.Web.Models.Entities
@model IEnumerable<Product>
@{
    var lang = ViewContext.RouteData.Values["lang"]?.ToString()
               ?? Context.Request.RouteValues["lang"]?.ToString()
               ?? "en";

    var brands = ViewBag.Brands as List<Brand> ?? new List<Brand>();
    var machineTypes = ViewBag.MachineTypes as List<MachineType> ?? new List<MachineType>();
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">

    @* --- 1. THANH LỌC (FIX LỖI NÚT TRẮNG & RESPONSIVE) --- *@
    <div class="mb-10 rounded-2xl bg-white p-5 sm:p-6 border border-slate-200 shadow-md">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 items-end">

            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500">@(lang == "vi" ? "Thương hiệu" : "Brand")</label>
                <select id="filter-brand" class="w-full rounded-lg border-slate-300 py-2.5 text-sm focus:border-[#004F9F] focus:ring-1 focus:ring-[#004F9F] bg-slate-50">
                    <option value="">@(lang == "vi" ? "Tất cả" : "All Brands")</option>
                    @foreach (var b in brands)
                    {
                        <!option value="@b.Id" @(ViewBag.CurrentBrandId == b.Id ? "selected" : "")>@b.Name</!option>
                    }
                </select>
            </div>

            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500">@(lang == "vi" ? "Loại máy" : "Machine Type")</label>
                <select id="filter-machineType" class="w-full rounded-lg border-slate-300 py-2.5 text-sm focus:border-[#004F9F] focus:ring-1 focus:ring-[#004F9F] bg-slate-50">
                    <option value="">@(lang == "vi" ? "Tất cả" : "All Types")</option>
                    @foreach (var m in machineTypes)
                    {
                        var mName = lang == "vi" ? m.NameVi : m.NameEn;
                        <!option value="@m.Id" @(ViewBag.CurrentMachineTypeId == m.Id ? "selected" : "")>@mName</!option>
                    }
                </select>
            </div>

            <div class="space-y-1.5">
                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500">@(lang == "vi" ? "Tìm kiếm" : "Search")</label>
                <input type="text" id="filter-search" value="@ViewBag.CurrentSearch"
                       placeholder="..."
                       class="w-full rounded-lg border-slate-300 py-2.5 text-sm focus:border-[#004F9F] focus:ring-1 focus:ring-[#004F9F]"
                       onkeypress="if(event.key === 'Enter') applyFilters()" />
            </div>

            <div class="flex gap-3 h-[42px]">
                <button onclick="applyFilters()"
                        class="flex-1 bg-[#004F9F] hover:bg-blue-800 text-white font-bold rounded-lg text-xs transition-all flex items-center justify-center gap-2 shadow-sm uppercase tracking-wider">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    @(lang == "vi" ? "Lọc" : "Filter")
                </button>

                @* Nút Xóa Lọc: Thêm viền (border-slate-300) và dùng SVG icon để không bị mất *@
                <button onclick="clearFilters()"
                        class="w-12 flex items-center justify-center bg-slate-100 hover:bg-slate-200 text-slate-600 border border-slate-300 rounded-lg transition-all shadow-sm"
                        title="@(lang == "vi" ? "Xóa lọc" : "Clear Filters")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    @* --- 2. GRID SẢN PHẨM (MÁY TÍNH 4 CỘT) --- *@
    <div>
        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 xl:gap-8">
                @foreach (var item in Model)
                {
                    var mainImage = item.Images?.FirstOrDefault(i => i.IsMain) ?? item.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault();
                    var imgSrc = (mainImage != null) ? mainImage.FilePath : "https://via.placeholder.com/400x400?text=No+Image";
                    var displayName = lang == "vi" ? item.NameVi : item.NameEn;
                    var displayDesc = lang == "vi" ? item.ShortDescriptionVi : item.ShortDescriptionEn;
                    var displaySlug = lang == "vi" ? item.SlugVi : item.SlugEn;
                    var detailUrl = $"/{lang}/medical/product/{displaySlug}";

                    <div class="group relative flex flex-col overflow-hidden rounded-xl bg-white shadow-sm border border-slate-100 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl">
                        <div class="relative aspect-square w-full overflow-hidden bg-white p-6 sm:p-8">
                            <img src="@imgSrc" alt="@displayName" class="h-full w-full object-contain transition-transform duration-700 group-hover:scale-105" />
                        </div>
                        <div class="flex flex-1 flex-col bg-[#004F9F] px-5 py-5 text-white">
                            <h3 class="mb-2 font-heading text-sm sm:text-base text-white font-bold uppercase tracking-wide line-clamp-2 min-h-[3rem]">@displayName</h3>
                            <p class="font-body text-[11px] font-light text-blue-100/80 line-clamp-3 mb-6">@displayDesc</p>
                            <div class="mt-auto flex items-center justify-between text-[10px] font-bold uppercase tracking-widest text-[#FFD43B]">
                                <span>@(lang == "vi" ? "Chi tiết" : "Details")</span>
                                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                            </div>
                        </div>
                        <a href="@detailUrl" class="absolute inset-0 z-10"></a>
                    </div>
                }
            </div>
        }
@* --- ĐOẠN UI PHÂN TRANG (PAGINATION) --- *@
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="mt-10 flex items-center justify-center gap-2">
                @* Nút Lùi *@
                <button onclick="goToPage(@(ViewBag.CurrentPage - 1))" disabled="@(ViewBag.CurrentPage <= 1)"
                        class="px-3 py-2 rounded-lg border border-slate-300 bg-white text-slate-500 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>

                @* Vòng lặp in số trang *@
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <button class="px-4 py-2 rounded-lg font-bold bg-[#004F9F] text-white shadow-sm pointer-events-none">@i</button>
                    }
                    else
                    {
                        <button onclick="goToPage(@i)" class="px-4 py-2 rounded-lg font-medium border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 transition-all">@i</button>
                    }
                }

                @* Nút Tiến *@
                <button onclick="goToPage(@(ViewBag.CurrentPage + 1))" disabled="@(ViewBag.CurrentPage >= ViewBag.TotalPages)"
                        class="px-3 py-2 rounded-lg border border-slate-300 bg-white text-slate-500 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
            </div>
        }
    </div>
</div>
@* --- 3. SCRIPT LOGIC --- *@
<script>
    // Hàm áp dụng lọc, mặc định khi đổi bộ lọc sẽ quay về trang 1
    function applyFilters(page = 1) {
        const brandId = document.getElementById('filter-brand').value;
        const machineTypeId = document.getElementById('filter-machineType').value;
        const searchTerm = document.getElementById('filter-search').value;

        if (typeof window.loadProducts === 'function') {
            window.loadProducts(window.currentCategoryId, brandId, machineTypeId, searchTerm, page);
        }
    }

    // Nút chuyển trang chuyên biệt
    function goToPage(page) {
        applyFilters(page);

        // (Tùy chọn) Cuộn nhẹ màn hình lên đầu danh sách sản phẩm
        const container = document.getElementById('product-list-container');
        if(container) {
            const y = container.getBoundingClientRect().top + window.scrollY - 100;
            window.scrollTo({ top: y, behavior: 'smooth' });
        }
    }

    // Xóa bộ lọc
    function clearFilters() {
        document.getElementById('filter-brand').value = "";
        document.getElementById('filter-machineType').value = "";
        document.getElementById('filter-search').value = "";

        if (typeof window.loadProducts === 'function') {
            window.loadProducts(window.currentCategoryId, '', '', '', 1);
        }
    }
</script>