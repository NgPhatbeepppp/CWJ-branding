@model Cw.Branding.Web.Models.Entities.News

@{
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Thêm tin tức mới</h1>
    <p class="text-gray-500 text-sm">Điền thông tin bên dưới để tạo bài viết mới.</p>
</div>

<form id="news-form" asp-action="Create" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <partial name="_Form" model="Model" />
</form>
@section Scripts {
    <partial name="_NewsEditorScripts" />
}