@model Cw.Branding.Web.Models.Entities.HeroSection

@{
    ViewData["Title"] = "Cấu hình Hero Banner";
    Layout = "_AdminLayout"; 
}

<div class="p-6">
    <div class="mb-6 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-slate-800">Cấu hình Hero Banner (Trang chủ)</h1>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="bg-white shadow-md rounded-lg p-8">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="BackgroundImage" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

            @* --- CỘT TRÁI: TIẾNG ANH --- *@
            <div class="space-y-4 border-r pr-8">
                <h3 class="font-bold text-blue-700 border-b pb-2">English Content</h3>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Main Headline (EN)</label>
                    <input asp-for="TitleEn" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Highlight Text (EN)</label>
                    <input asp-for="HighlightEn" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Description (EN)</label>
                    <textarea asp-for="DescriptionEn" rows="3" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-sm font-medium text-gray-700">CTA 1 Text</label>
                        <input asp-for="Cta1TextEn" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">CTA 2 Text</label>
                        <input asp-for="Cta2TextEn" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                    </div>
                </div>
            </div>

            @* --- CỘT PHẢI: TIẾNG VIỆT --- *@
            <div class="space-y-4">
                <h3 class="font-bold text-red-700 border-b pb-2">Nội dung Tiếng Việt</h3>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Tiêu đề chính (VI)</label>
                    <input asp-for="TitleVi" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Chữ nhấn mạnh (VI)</label>
                    <input asp-for="HighlightVi" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">Mô tả ngắn (VI)</label>
                    <textarea asp-for="DescriptionVi" rows="3" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Nút 1 (VI)</label>
                        <input asp-for="Cta1TextVi" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Nút 2 (VI)</label>
                        <input asp-for="Cta2TextVi" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                    </div>
                </div>
            </div>
        </div>

        @* --- PHẦN CHUNG: ẢNH & LINKS --- *@
        <div class="mt-8 pt-6 border-t grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
                <label class="block text-sm font-medium text-gray-700">Background Image (1920x800)</label>
                <input type="file" name="uploadBg" class="mt-2 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                @if (!string.IsNullOrEmpty(Model.BackgroundImage))
                {
                    <img src="@Model.BackgroundImage" class="mt-4 w-full max-h-40 object-cover rounded border" />
                }
            </div>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Link CTA 1 (URL)</label>
                    <input asp-for="Cta1Url" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Link CTA 2 (URL)</label>
                    <input asp-for="Cta2Url" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm p-2 border" />
                </div>
            </div>
        </div>

        <div class="mt-8 flex justify-end">
            <button type="submit" class="bg-[#004F9F] text-white px-10 py-3 rounded-md font-bold hover:bg-blue-800 transition-colors shadow-lg">
                LƯU THAY ĐỔI
            </button>
        </div>
    </form>
</div>