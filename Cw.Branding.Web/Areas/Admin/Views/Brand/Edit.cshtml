@model Cw.Branding.Web.Models.Entities.Brand
@{
    ViewData["Title"] = "Chỉnh sửa Hãng";
    Layout = "_AdminLayout";
}

<div class="p-6 bg-white rounded-lg shadow-md">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Chỉnh sửa: @Model.Name</h2>
        <a asp-action="Index" class="text-gray-500 hover:text-blue-600 italic text-sm">← Quay lại danh sách</a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="space-y-4">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="LogoPath" /> @* Giữ lại đường dẫn ảnh cũ nếu không đổi *@

        <div>
            <label class="block text-sm font-medium text-gray-700">Tên Hãng</label>
            <input asp-for="Name" class="mt-1 block w-full border border-gray-300 rounded-md p-2 focus:ring-blue-500" />
            <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Logo hiện tại</label>
            <div class="mt-2 mb-4">
                @if (!string.IsNullOrEmpty(Model.LogoPath))
                {
                    <img src="@Model.LogoPath" class="h-20 w-auto border rounded p-1 mb-2" />
                }
                <input type="file" name="logoFile" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                <p class="text-xs text-gray-400 mt-1">Để trống nếu không muốn thay đổi ảnh.</p>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Thứ tự hiển thị</label>
                <input asp-for="DisplayOrder" type="number" class="mt-1 block w-full border border-gray-300 rounded-md p-2" />
            </div>
            <div class="flex items-center mt-6">
                <input asp-for="IsActive" type="checkbox" class="h-4 w-4 text-blue-600 border-gray-300 rounded" />
                <label asp-for="IsActive" class="ml-2 block text-sm text-gray-900 font-bold">Kích hoạt</label>
            </div>
        </div>

        <div class="pt-4 border-t">
            <button type="submit" class="bg-[#004F9F] text-white px-6 py-2 rounded-md hover:bg-blue-800 transition shadow-md">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>