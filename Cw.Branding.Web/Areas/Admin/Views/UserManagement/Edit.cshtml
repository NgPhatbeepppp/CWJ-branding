@model Cw.Branding.Web.Models.Entities.AppUser
@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
}

<div class="p-6 max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Index" class="text-blue-600 hover:underline text-sm">← Quay lại danh sách</a>
        <h2 class="text-2xl font-bold text-blue-900 mt-2">Chỉnh sửa: @Model.Username</h2>
    </div>

    <form asp-action="Edit" method="post" class="bg-white shadow-md rounded-lg p-6 space-y-4 border border-gray-100">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
        <input type="hidden" asp-for="Id" />

        <div>
            <label class="block text-sm font-medium text-gray-700 bg-gray-50 p-2 rounded">
                Username: <span class="font-bold">@Model.Username</span> (Không thể thay đổi)
            </label>
            <input type="hidden" asp-for="Username" />
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1">Vùng miền quản lý</label>
            <select asp-for="Region" class="w-full rounded-md border-gray-300 shadow-sm focus:border-brand-primary focus:ring-brand-primary"
                    asp-items="Html.GetEnumSelectList<Cw.Branding.Web.Models.Enums.ContactRegion>()">
                <option value="">-- Chọn khu vực --</option>
            </select>
            <span asp-validation-for="Region" class="text-red-500 text-xs"></span>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Họ và tên</label>
            <input asp-for="FullName" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Email</label>
            <input asp-for="Email" type="email" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Phân quyền (Role)</label>
                <select asp-for="RoleId" asp-items="ViewBag.Roles" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500"></select>
            </div>
            <div class="flex items-center pt-6">
                <input asp-for="IsActive" type="checkbox" class="h-4 w-4 text-blue-600 border-gray-300 rounded" />
                <label class="ml-2 block text-sm text-gray-700 font-medium">Kích hoạt tài khoản</label>
            </div>
        </div>

        <div class="pt-4 border-t border-gray-100 flex justify-between items-center">
            <span class="text-xs text-gray-400 italic">Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded transition duration-200">
                CẬP NHẬT
            </button>
        </div>
    </form>
</div>