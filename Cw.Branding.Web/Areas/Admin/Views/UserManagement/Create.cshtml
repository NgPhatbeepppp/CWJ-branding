@model Cw.Branding.Web.Models.Entities.AppUser
@{
    ViewData["Title"] = "Thêm tài khoản mới";
}

<div class="p-6 max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Index" class="text-blue-600 hover:underline text-sm">← Quay lại danh sách</a>
        <h2 class="text-2xl font-bold text-blue-900 mt-2">Thêm tài khoản mới</h2>
    </div>

    <form asp-action="Create" method="post" class="bg-white shadow-md rounded-lg p-6 space-y-4 border border-gray-100">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Tên đăng nhập (Username)</label>
                <input asp-for="Username" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500" required />
                <span asp-validation-for="Username" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Mật khẩu khởi tạo</label>
                <input type="password" name="Password" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500" required />
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Họ và tên</label>
            <input asp-for="FullName" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Email</label>
            <input asp-for="Email" type="email" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Phân quyền (Role)</label>
                <select asp-for="RoleId" asp-items="ViewBag.Roles" class="mt-1 block w-full border border-gray-300 rounded-md p-2 outline-none focus:ring-1 focus:ring-blue-500"></select>
            </div>
            <div class="flex items-center pt-6">
                <input asp-for="IsActive" type="checkbox" class="h-4 w-4 text-blue-600 border-gray-300 rounded" checked />
                <label class="ml-2 block text-sm text-gray-700 font-medium">Kích hoạt tài khoản</label>
            </div>
        </div>

        <div class="pt-4 border-t border-gray-100 flex justify-end">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded transition duration-200">
                LƯU TÀI KHOẢN
            </button>
        </div>
    </form>
</div>
<script>
    document.querySelector('input[name="Username"]').addEventListener('blur', function() {
        const username = this.value;
        if (!username) return;

        fetch(`/${document.documentElement.lang}/Admin/UserManagement/CheckUsername?username=${username}`)
            .then(res => res.json())
            .then(data => {
                if (!data.isAvailable) {
                    alert("Tên đăng nhập này đã có người dùng!");
                    this.classList.add('border-red-500');
                } else {
                    this.classList.remove('border-red-500');
                }
            });
    });
</script>