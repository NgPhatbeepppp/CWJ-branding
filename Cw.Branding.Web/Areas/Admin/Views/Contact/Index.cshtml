@using Cw.Branding.Web.Models.Enums
@model IEnumerable<Cw.Branding.Web.Models.Entities.ContactFormEntry>

@{
    ViewData["Title"] = "Customer Leads Management";
    Layout = "_AdminLayout"; // Giả định anh đã có layout admin
}

<div class="p-6">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-slate-800">Customer Leads</h1>

        <div class="flex gap-2 bg-slate-100 p-1 rounded-lg">
            <a href="@Url.Action("Index", "Contact", new { area = "Admin", status = (ContactStatus?)null })"
               class="px-4 py-1.5 rounded-md text-sm @(ViewBag.CurrentStatus == null ? "bg-white shadow-sm text-blue-600 font-semibold" : "text-slate-500")">All</a>
            <a href="@Url.Action("Index", new { area = "Admin", status = ContactStatus.New })"
               class="px-4 py-1.5 rounded-md text-sm @((ContactStatus?)ViewBag.CurrentStatus == ContactStatus.New ? "bg-white shadow-sm text-blue-600 font-semibold" : "text-slate-500")">New</a>
            <a href="@Url.Action("Index", new { area = "Admin", status = ContactStatus.InProcess })"
               class="px-4 py-1.5 rounded-md text-sm @((ContactStatus?)ViewBag.CurrentStatus == ContactStatus.InProcess ? "bg-white shadow-sm text-blue-600 font-semibold" : "text-slate-500")">Processing</a>
            <a href="@Url.Action("Export", "Contact", new { area = "Admin", status = ViewBag.CurrentStatus })"
               class="flex items-center gap-2 px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-blue-800 transition-all shadow-sm hover:shadow-md active:transform active:scale-95">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                EXPORT EXCEL
            </a>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
                    <th class="px-6 py-4 font-semibold">Date</th>
                    <th class="px-6 py-4 font-semibold">Customer</th>
                    <th class="px-6 py-4 font-semibold">Product/Service</th>
                    <th class="px-6 py-4 font-semibold">Status</th>
                    <th class="px-6 py-4 font-semibold">Handled By</th>
                    <th class="px-6 py-4 font-semibold">Region</th>
                    <th class="px-6 py-4 font-semibold text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    // Logic style cho dòng chưa đọc
                    string rowClass = item.IsRead ? "text-slate-600" : "font-bold text-slate-900 bg-blue-50/30";

                    <tr class="hover:bg-slate-50 transition-colors @rowClass">
                        <td class="px-6 py-4 text-sm">
                            @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm">@item.Name</div>
                            <div class="text-xs text-slate-400 font-normal">@item.Email</div>
                        </td>
                        <td class="px-6 py-4 text-sm">
                            <span class="bg-slate-100 text-slate-600 px-2 py-1 rounded text-xs">@item.SelectedProduct</span>
                        </td>
                        <td class="px-6 py-4">
                            @switch (item.ProcessingStatus)
                            {
                                case ContactStatus.New:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        @if (!item.IsRead)
                                        {
                                            <span class="w-1.5 h-1.5 bg-blue-600 rounded-full mr-1.5 animate-pulse"></span>
                                        }
                                        NEW
                                    </span>
                                    break;
                                case ContactStatus.InProcess:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">PROCESSING</span>
                                    break;
                                case ContactStatus.Completed:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">COMPLETED</span>
                                    break;
                                default:
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">REJECTED</span>
                                    break;
                            }
                        </td>
                        <td class="px-6 py-4 text-xs text-slate-500 font-normal">
                            @(item.ReadByAdminId ?? "-")
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 rounded text-xs font-medium
                                                @(item.Region == ContactRegion.North ? "bg-purple-100 text-purple-700" :
                                                                              item.Region == ContactRegion.Central ? "bg-orange-100 text-orange-700" : "bg-teal-100 text-teal-700")">
                                @item.Region
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a href="@Url.Action("Details", new { id = item.Id })"
                               class="text-blue-600 hover:text-blue-900 text-sm font-semibold underline decoration-2 underline-offset-4">
                                View Detail
                            </a>
                        </td>
                       
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="p-12 text-center text-slate-400">
                No leads found.
            </div>
        }
    </div>
</div>