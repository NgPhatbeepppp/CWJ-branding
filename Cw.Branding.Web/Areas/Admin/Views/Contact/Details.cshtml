@using Cw.Branding.Web.Models.Enums
@model Cw.Branding.Web.Models.Entities.ContactFormEntry

@{
    ViewData["Title"] = "Lead Details - " + Model.Name;
    Layout = "_AdminLayout";
}

<div class="p-8 max-w-7xl mx-auto bg-brand-bg min-h-screen">
    @* Navigation *@
    <div class="mb-8">
        <a href="@Url.Action("Index", "Contact", new { area = "Admin" })" class="inline-flex items-center gap-2 text-slate-500 hover:text-brand-primary font-medium transition-colors group">
            <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Quay lại danh sách
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        @* CỘT TRÁI: THÔNG TIN CHÍNH (8 COLUMNS) *@
        <div class="lg:col-span-8 space-y-6">

            @* Card chính: Header & Thông tin liên hệ *@
            <div class="bg-white rounded-lg shadow-card border border-slate-200 overflow-hidden">
                <div class="p-8 border-b border-slate-100">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                        <div>
                            <span class="text-xs font-bold text-brand-primary uppercase tracking-widest">Lead Information</span>
                            <h1 class="text-3xl font-bold text-slate-900 mt-1">@Model.Name</h1>
                            <p class="text-slate-400 text-sm mt-1 flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                Gửi lúc: @Model.CreatedAt.ToString("f")
                            </p>
                        </div>

                        @* Badges: Product & Region được tách riêng, không đè lên text *@
                        <div class="flex flex-wrap gap-3">
                            <div class="flex flex-col items-end">
                                <span class="text-[10px] font-bold uppercase tracking-tighter text-slate-400 mb-1">Sản phẩm quan tâm</span>
                                <span class="bg-blue-50 text-brand-primary px-3 py-1.5 rounded-md font-semibold text-xs border border-blue-100">
                                    @Model.SelectedProduct
                                </span>
                            </div>
                            <div class="flex flex-col items-end">
                                <span class="text-[10px] font-bold uppercase tracking-tighter text-slate-400 mb-1">Khu vực</span>
                                <span class="px-3 py-1.5 rounded-md font-semibold text-xs border
                                    @(Model.Region == ContactRegion.North ? "bg-purple-50 text-purple-700 border-purple-100" :
                                                                            Model.Region == ContactRegion.Central ? "bg-orange-50 text-orange-700 border-orange-100" :
                                                                            "bg-teal-50 text-teal-700 border-teal-100")">
                                    @Model.Region
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-8 bg-slate-50/50">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">Contact Details</h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        @* Company *@
                        <div class="space-y-1">
                            <p class="text-[11px] text-slate-400 font-medium">Công ty</p>
                            <p class="text-slate-700 font-semibold flex items-center gap-2">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                                @(string.IsNullOrEmpty(Model.Company) ? "N/A" : Model.Company)
                            </p>
                        </div>
                        @* Email *@
                        <div class="space-y-1">
                            <p class="text-[11px] text-slate-400 font-medium">Email</p>
                            <a href="mailto:@Model.Email" class="text-brand-primary hover:underline font-semibold flex items-center gap-2">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="2" /></svg>
                                @Model.Email
                            </a>
                        </div>
                        @* Phone *@
                        <div class="space-y-1">
                            <p class="text-[11px] text-slate-400 font-medium">Số điện thoại</p>
                            <p class="text-slate-700 font-semibold flex items-center gap-2">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-width="2" /></svg>
                                @(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            @* Message Content Card *@
            <div class="bg-white rounded-lg shadow-card border border-slate-200 p-8">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Message Content</h4>
                <div class="bg-white rounded-lg p-6 text-slate-800 text-lg leading-relaxed whitespace-pre-wrap border border-slate-100 shadow-inner min-h-[200px]">
                    @Model.Message
                </div>
            </div>
        </div>

        @* CỘT PHẢI: XỬ LÝ & NHẬT KÝ (4 COLUMNS) *@
        <div class="lg:col-span-4 space-y-6">

            @* Lead Processing *@
            <div class="bg-white rounded-lg shadow-card border border-slate-200 p-6 sticky top-6">
                <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                    <span class="w-2 h-6 bg-brand-primary rounded-full"></span>
                    Lead Processing
                </h3>

                <form asp-action="UpdateStatus" method="post" class="space-y-5">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Trạng thái xử lý</label>
                        <select name="status" class="w-full rounded-md border-slate-300 focus:border-brand-primary focus:ring-brand-primary text-sm p-2.5 bg-slate-50">
                            <!option value="@ContactStatus.New" @(Model.ProcessingStatus == ContactStatus.New ? "selected" : "")>Mới (New Lead)</!option>
                            <!option value="@ContactStatus.InProcess" @(Model.ProcessingStatus == ContactStatus.InProcess ? "selected" : "")>Đang xử lý (Processing)</!option>
                            <!option value="@ContactStatus.Completed" @(Model.ProcessingStatus == ContactStatus.Completed ? "selected" : "")>Hoàn thành (Completed)</!option>
                            <!option value="@ContactStatus.Rejected" @(Model.ProcessingStatus == ContactStatus.Rejected ? "selected" : "")>Từ chối / Spam</!option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Ghi chú nội bộ</label>
                        <textarea name="adminNotes" rows="5" placeholder="Nhập ghi chú theo dõi tại đây..."
                                  class="w-full rounded-md border-slate-300 focus:border-brand-primary focus:ring-brand-primary text-sm p-3 bg-slate-50">@Model.AdminNotes</textarea>
                    </div>

                    <button type="submit" class="w-full btn-primary py-3 shadow-lg">
                        Cập nhật thay đổi
                    </button>
                </form>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mt-4 p-4 bg-green-50 text-green-700 text-sm rounded-md border border-green-100 flex items-center gap-3 animate-pulse">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" /></svg>
                        @TempData["SuccessMessage"]
                    </div>
                }

                @* Internal Log được dời sang đây để cân bằng layout *@
                <div class="mt-8 pt-6 border-t border-slate-100">
                    <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Thông tin hệ thống</h4>
                    <div class="text-xs text-slate-500 space-y-2 bg-slate-50 p-3 rounded-md">
                        <p class="flex justify-between"><span>Người xem:</span> <span class="font-semibold text-slate-900">@(Model.ReadByAdminId ?? "Chưa xem")</span></p>
                        <p class="flex justify-between"><span>Thời gian xem:</span> <span class="font-semibold text-slate-900">@(Model.ReadAt?.ToString("g") ?? "N/A")</span></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>