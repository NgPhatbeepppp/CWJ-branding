@model IEnumerable<Cw.Branding.Web.Models.Entities.MachineType>
@{
    ViewData["Title"] = "Quản lý Loại Máy";
    Layout = "_AdminLayout";
}

<div class="p-6 bg-white rounded-lg shadow-md">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Danh sách Loại Máy</h2>
        <a asp-action="Create" class="bg-[#004F9F] hover:bg-blue-800 text-white px-4 py-2 rounded-md flex items-center transition">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"></path></svg>
            Thêm Loại Máy
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tên (VN)</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tên (EN)</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Thứ tự</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trạng thái</th>
                    <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Thao tác</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">@item.NameVi</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@item.NameEn</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">@item.DisplayOrder</td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="px-2 py-1 text-xs font-bold rounded @(item.IsActive ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")">
                                @(item.IsActive ? "Hiện" : "Ẩn")
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium space-x-3">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-900">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline" onsubmit="return confirm('Xóa loại máy này có thể ảnh hưởng đến sản phẩm liên quan. Anh vẫn muốn xóa?');">
                                <button type="submit" class="text-red-600 hover:text-red-900">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>