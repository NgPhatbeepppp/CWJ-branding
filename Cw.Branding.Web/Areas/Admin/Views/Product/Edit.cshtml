@model Cw.Branding.Web.Models.Entities.Product
@{
    ViewData["Title"] = "Cập nhật Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm text-gray-500 hover:text-[#004F9F]">← Quay lại danh sách</a>
    <h1 class="mt-2 text-2xl font-bold text-gray-800">Cập nhật Sản phẩm: @Model.NameVi</h1>
</div>

<form asp-action="Edit" method="post" class="space-y-6">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

        <div class="col-span-2 space-y-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-gray-700 border-b pb-2">Thông tin chung</h2>
            <div asp-validation-summary="All" class="text-sm text-red-600"></div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Code" class="block text-sm font-medium text-gray-700">Mã sản phẩm *</label>
                    <input asp-for="Code" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm" required />
                    <span asp-validation-for="Code" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="DisplayOrder" class="block text-sm font-medium text-gray-700">Thứ tự hiển thị</label>
                    <input asp-for="DisplayOrder" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="NameVi" class="block text-sm font-medium text-gray-700">Tên sản phẩm (VN) *</label>
                    <input asp-for="NameVi" id="NameVi" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm" required />
                    <span asp-validation-for="NameVi" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="SlugVi" class="block text-sm font-medium text-gray-700">Slug (VN)</label>
                    <input asp-for="SlugVi" id="SlugVi" class="mt-1 block w-full rounded-md border-gray-300 bg-gray-50 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm" readonly />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="NameEn" class="block text-sm font-medium text-gray-700">Tên sản phẩm (EN)</label>
                    <input asp-for="NameEn" id="NameEn" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm" />
                </div>
                <div>
                    <label asp-for="SlugEn" class="block text-sm font-medium text-gray-700">Slug (EN)</label>
                    <input asp-for="SlugEn" id="SlugEn" class="mt-1 block w-full rounded-md border-gray-300 bg-gray-50 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm" readonly />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="ShortDescriptionVi" class="block text-sm font-medium text-gray-700">Mô tả ngắn (VN)</label>
                    <textarea asp-for="ShortDescriptionVi" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm"></textarea>
                </div>
                <div>
                    <label asp-for="ShortDescriptionEn" class="block text-sm font-medium text-gray-700">Mô tả ngắn (EN)</label>
                    <textarea asp-for="ShortDescriptionEn" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm"></textarea>
                </div>
            </div>
        </div>

        <div class="space-y-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-gray-700 border-b pb-2">Phân loại & Trạng thái</h2>

            <div>
                <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700">Chuyên khoa *</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm">
                    <option value="">-- Chọn chuyên khoa --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="BrandId" class="block text-sm font-medium text-gray-700">Hãng sản xuất</label>
                <select asp-for="BrandId" asp-items="ViewBag.Brands" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm">
                    <option value="">-- Chọn hãng --</option>
                </select>
            </div>

            <div>
                <label asp-for="MachineTypeId" class="block text-sm font-medium text-gray-700">Loại máy</label>
                <select asp-for="MachineTypeId" asp-items="ViewBag.MachineTypes" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-[#004F9F] focus:ring-[#004F9F] sm:text-sm">
                    <option value="">-- Chọn loại máy --</option>
                </select>
            </div>

            <h2 class="text-lg font-semibold text-gray-700 border-b pb-2 pt-4">Cấu hình hiển thị</h2>

            <div class="flex items-center">
                <input asp-for="IsActive" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-[#004F9F] focus:ring-[#004F9F]" />
                <label asp-for="IsActive" class="ml-2 block text-sm text-gray-900">Hiển thị (Active)</label>
            </div>

            <div class="flex items-center">
                <input asp-for="IsFeatured" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-yellow-500 focus:ring-yellow-500" />
                <label asp-for="IsFeatured" class="ml-2 block text-sm text-gray-900">Sản phẩm nổi bật (Trang chủ)</label>
            </div>

            <div class="pt-4">
                <button type="submit" class="w-full justify-center rounded-md border border-transparent bg-green-600 py-3 px-4 text-sm font-bold text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                    Lưu Thay Đổi
                </button>
            </div>
        </div>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-gray-700 border-b pb-2 mb-6">Nội dung chi tiết & Thông số kỹ thuật</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div class="bg-blue-50 p-3 rounded-md border border-blue-100 mb-4">
                    <h3 class="font-bold text-blue-800">🇻🇳 Ngôn ngữ: Tiếng Việt</h3>
                </div>

                <div>
                    <label asp-for="DescriptionVi" class="block text-sm font-medium text-gray-700 mb-2">Mô tả chi tiết</label>
                    <textarea asp-for="DescriptionVi" class="rich-editor block w-full"></textarea>
                </div>

                <div>
                    <label asp-for="TechnicalSpecsVi" class="block text-sm font-medium text-gray-700 mb-2">Thông số kỹ thuật</label>
                    <textarea asp-for="TechnicalSpecsVi" class="rich-editor block w-full"></textarea>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-gray-50 p-3 rounded-md border border-gray-200 mb-4">
                    <h3 class="font-bold text-gray-700">🇬🇧 Ngôn ngữ: Tiếng Anh</h3>
                </div>

                <div>
                    <label asp-for="DescriptionEn" class="block text-sm font-medium text-gray-700 mb-2">Mô tả chi tiết</label>
                    <textarea asp-for="DescriptionEn" class="rich-editor block w-full"></textarea>
                </div>

                <div>
                    <label asp-for="TechnicalSpecsEn" class="block text-sm font-medium text-gray-700 mb-2">Thông số kỹ thuật</label>
                    <textarea asp-for="TechnicalSpecsEn" class="rich-editor block w-full"></textarea>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.tiny.cloud/1/dl99a4afekhkasmei0sgcju4swck5lwhiy19phre0afu889m/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>

    <script>
        const AdminTools = {
            generateSlug: function (text) {
                if (!text) return '';
                return text.toString().toLowerCase()
                    .replace(/á|à|ả|ạ|ã|ă|ắ|ằ|ẳ|ẵ|ặ|â|ấ|ầ|ẩ|ẫ|ậ/g, 'a')
                    .replace(/é|è|ẻ|ẽ|ẹ|ê|ế|ề|ể|ễ|ệ/g, 'e')
                    .replace(/i|í|ì|ỉ|ĩ|ị/g, 'i')
                    .replace(/ó|ò|ỏ|õ|ọ|ô|ố|ồ|ổ|ỗ|ộ|ơ|ớ|ờ|ở|ỡ|ợ/g, 'o')
                    .replace(/ú|ù|ủ|ũ|ụ|ư|ứ|ừ|ử|ữ|ự/g, 'u')
                    .replace(/ý|ỳ|ỷ|ỹ|ỵ/g, 'y')
                    .replace(/đ/g, 'd')
                    .replace(/\s+/g, '-')
                    .replace(/[^\w\-]+/g, '')
                    .replace(/\-\-+/g, '-')
                    .replace(/^-+/, '')
                    .replace(/-+$/, '');
            },

            initRichEditor: function (selector, uploadUrl) {
                tinymce.init({
                    selector: selector,
                    plugins: 'image code table lists link',
                    toolbar: 'blocks | bold italic | bullist numlist | h2 h3 | table | link image | code',
                    images_upload_url: uploadUrl,
                    automatic_uploads: true,
                    images_upload_credentials: true,
                    file_picker_types: 'image',
                    valid_elements: '*[*]',
                    entity_encoding: "raw",
                    height: 400,
                    setup: function (editor) {
                        editor.on('change', function () {
                            tinymce.triggerSave();
                        });
                    }
                });
            }
        };

        document.addEventListener("DOMContentLoaded", function () {
             AdminTools.initRichEditor('.rich-editor', '/Admin/Product/UploadEditorImage');

             // Lưu ý: Đối với trang Edit, thường người ta sẽ không tự động đổi Slug khi sửa Tên
             // để tránh làm hỏng link SEO cũ. Nếu anh vẫn muốn auto-slug khi Edit, hãy bỏ comment đoạn dưới.

             /*
             const nameViInput = document.getElementById('NameVi');
             const slugViInput = document.getElementById('SlugVi');
             if(nameViInput && slugViInput) {
                 nameViInput.addEventListener('keyup', function () {
                     slugViInput.value = AdminTools.generateSlug(this.value);
                 });
             }

             const nameEnInput = document.getElementById('NameEn');
             const slugEnInput = document.getElementById('SlugEn');
             if(nameEnInput && slugEnInput) {
                 nameEnInput.addEventListener('keyup', function () {
                     slugEnInput.value = AdminTools.generateSlug(this.value);
                 });
             }
             */
         });
    </script>
}