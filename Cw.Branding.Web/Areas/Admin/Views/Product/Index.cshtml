@Html.AntiForgeryToken()
@model IEnumerable<Cw.Branding.Web.Models.Entities.Product>
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Danh sách Sản phẩm</h1>
        <p class="text-sm text-gray-500 mt-1">Quản lý toàn bộ sản phẩm và thiết bị y tế trên hệ thống</p>
    </div>
    <div class="flex gap-2">
        <a asp-action="Create" class="inline-flex items-center rounded-md bg-[#004F9F] px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-blue-800 transition-all">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Thêm Sản phẩm mới
        </a>
        <button onclick="window.location.reload()" class="rounded bg-[#004F9F] px-4 py-2 text-white hover:bg-blue-800 transition-all">
            <i class="fas fa-sync"></i> Làm mới danh sách
        </button>
    </div>
   
</div>
@* --- Thanh Filter (Đã thêm ô tìm kiếm & tối ưu) --- *@
<div class="mb-6 rounded-lg bg-white p-4 shadow-sm border border-gray-100">
    @* Form dùng method GET để có thể copy URL đã lọc *@
    <form asp-action="Index" method="get" class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">

        <div class="md:col-span-3">
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Tìm kiếm</label>
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tên hoặc mã SP..."
                   class="w-full rounded border-gray-300 text-sm focus:ring-[#004F9F] focus:border-[#004F9F]" />
        </div>

        <div class="md:col-span-3">
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Chuyên khoa</label>
            <select name="categoryId" asp-items="ViewBag.Categories" class="w-full rounded border-gray-300 text-sm">
                <option value="">-- Tất cả --</option>
            </select>
        </div>

        <div class="md:col-span-2">
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Hãng</label>
            <select name="brandId" asp-items="ViewBag.Brands" class="w-full rounded border-gray-300 text-sm">
                <option value="">-- Tất cả --</option>
            </select>
        </div>

        <div class="md:col-span-2">
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Trạng thái</label>
            <select name="isActive" class="w-full rounded border-gray-300 text-sm">
                <option value="">Tất cả</option>
                <option value="true" selected="@(ViewBag.IsActive == true)">Hiển thị</option>
                <option value="false" selected="@(ViewBag.IsActive == false)">Đang ẩn</option>
            </select>
        </div>

        <div class="md:col-span-2 flex gap-2">
            @* Nút Lọc - Màu Primary Blue của dự án *@
            <button type="submit" class="flex-1 inline-flex items-center justify-center rounded-md bg-[#004F9F] px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-blue-800 transition-all">
                <i class="fas fa-filter mr-2 text-xs"></i> Lọc
            </button>

            @* Nút Xóa lọc - Thêm chữ và dùng style Outline cho cân đối *@
            <a asp-action="Index" class="flex-1 inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-bold text-gray-700 shadow-sm hover:bg-gray-50 hover:text-[#004F9F] transition-all" title="Xóa tất cả bộ lọc">
                <i class="fas fa-undo mr-2 text-xs"></i> Xóa lọc
            </a>
        </div>
    </form>
</div>
@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-4 rounded-md bg-green-50 p-4 border border-green-200">
        <div class="flex">
            <div class="flex-shrink-0"><svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg></div>
            <div class="ml-3"><p class="text-sm font-medium text-green-800">@TempData["SuccessMessage"]</p></div>
        </div>
    </div>
}

<div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-gray-500 w-24">Hình ảnh</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Thông tin Sản phẩm</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Phân loại</th>
                @* Bổ sung Header cho Thứ tự *@
                <th scope="col" class="px-6 py-3 text-center text-xs font-bold uppercase tracking-wider text-gray-500 w-28">Thứ tự</th>
                <th scope="col" class="px-6 py-3 text-center text-xs font-bold uppercase tracking-wider text-gray-500 w-32">Trạng thái</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-bold uppercase tracking-wider text-gray-500 w-24">Thao tác</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
            @if (!Model.Any())
            {
                @* Cập nhật colspan thành 6 *@
                <tr><td colspan="6" class="px-6 py-8 text-center text-sm text-gray-500">Chưa có sản phẩm nào. Hãy thêm mới!</td></tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    var mainImg = item.Images?.FirstOrDefault(i => i.IsMain) ?? item.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault();

                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (mainImg != null)
                            {
                                <img src="@mainImg.FilePath" class="h-12 w-12 rounded-md object-cover border border-gray-200 shadow-sm" alt="@item.NameVi" />
                            }
                            else
                            {
                                <div class="h-12 w-12 rounded-md bg-gray-100 border border-gray-200 flex items-center justify-center text-gray-400 text-[10px] font-medium shadow-sm">
                                    No Img
                                </div>
                            }
                        </td>

                        <td class="px-6 py-4">
                            <div class="text-sm font-bold text-[#004F9F]">@item.NameVi</div>
                            <div class="text-xs text-gray-500 mt-1">Mã: <span class="font-medium text-gray-800">@item.Code</span></div>
                        </td>

                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700 border border-blue-100">
                                @(item.Category?.NameVi ?? "Chưa phân loại")
                            </span>
                            @if (item.Brand != null)
                            {
                                <div class="text-[11px] text-gray-500 mt-1 pl-1">Hãng: @item.Brand.Name</div>
                            }
                        </td>

                        @* Cột Thứ tự hiển thị *@
                        <td>
                            <input type="number"
                                   value="@item.DisplayOrder"
                                   class="w-20 border rounded px-2 py-1 display-order-input"
                                   data-id="@item.Id"
                                   onchange="saveOrder(this)" />
                            <span class="text-xs text-green-600 hidden saved-msg">✔ Đã lưu</span>
                        </td>

                        @* Cột Trạng thái *@
                        <td class="px-6 py-4 whitespace-nowrap text-center">
                            @if (item.IsActive)
                            {
                                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Hiển thị</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">Đang ẩn</span>
                            }

                            @if (item.IsFeatured)
                            {
                                <div class="mt-2 text-[10px] font-bold text-yellow-600 flex items-center justify-center gap-1">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                    NỔI BẬT
                                </div>
                            }
                        </td>

                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-[#004F9F] hover:text-blue-800 mr-3 transition-colors">Sửa</a>
                            <button type="button" onclick="openDeleteModal(@item.Id, '@Html.Raw(item.NameVi)')" class="text-red-500 hover:text-red-700 transition-colors">
                                Xóa
                            </button>
                            <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" class="hidden"></form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-gray-900/60 backdrop-blur-sm transition-opacity">
    <div id="deleteModalContent" class="bg-white rounded-lg shadow-2xl w-full max-w-md p-6 transform transition-all scale-95 opacity-0 duration-200">
        <div class="flex items-center justify-center w-14 h-14 mx-auto bg-red-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
        </div>

        <h3 class="text-xl font-bold text-center text-gray-900 mb-2">Xác nhận xóa sản phẩm</h3>

        <p class="text-sm text-center text-gray-600 mb-6">
            Bạn đang chuẩn bị xóa: <br />
            <strong id="modalProductName" class="text-red-600 text-base mt-1 block"></strong>
            <br />
            Toàn bộ dữ liệu và <span class="font-bold">thư mục hình ảnh</span> của sản phẩm này sẽ bị xóa vĩnh viễn khỏi máy chủ. Hành động này không thể hoàn tác!
        </p>

        <div class="flex justify-center gap-3">
            <button type="button" onclick="closeDeleteModal()" class="px-5 py-2.5 bg-gray-100 text-gray-700 font-bold rounded-md hover:bg-gray-200 transition-colors">
                Hủy bỏ
            </button>
            <button type="button" id="btnConfirmDelete" class="px-5 py-2.5 bg-red-600 text-white font-bold rounded-md hover:bg-red-700 shadow-md transition-colors">
                Xóa ngay!
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function saveOrder(input) {
            const id = input.getAttribute('data-id');
            const order = input.value;
            const msg = input.nextElementSibling; // Cái span 'saved-msg'

            // Lấy lang từ URL hiện tại (VD: /vi/admin/product -> lấy 'vi')
            const pathParts = window.location.pathname.split('/');
            const lang = pathParts[1] || 'en';

            // Hiện loading nhẹ
            msg.innerText = "...";
            msg.classList.remove('hidden', 'text-green-600');
            msg.classList.add('text-gray-400');

            // Gọi API lưu vào DB
            fetch(`/${lang}/Admin/Product/UpdateOrder?id=${id}&order=${order}`, {
                method: 'POST',
                headers: {
                    // QUAN TRỌNG: Phải gửi token này lên nếu không Server sẽ chặn (Lỗi 400)
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    msg.innerText = "✔ Đã lưu";
                    msg.classList.replace('text-gray-400', 'text-green-600');
                    setTimeout(() => msg.classList.add('hidden'), 2000);
                } else {
                    alert('Lỗi: ' + (data.message || 'Không thể cập nhật'));
                    msg.classList.add('hidden');
                }
            })
            .catch(err => {
                console.error("Lỗi AJAX:", err);
                alert("Lỗi kết nối máy chủ!");
            });
        }
    </script>
}