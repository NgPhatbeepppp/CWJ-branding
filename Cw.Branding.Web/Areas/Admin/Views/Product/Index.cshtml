@model IEnumerable<Cw.Branding.Web.Models.Entities.Product>
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Quản lý Sản phẩm</h1>
        <p class="text-sm text-gray-500">Danh sách tất cả thiết bị và giải pháp y tế</p>
    </div>
    <a asp-action="Create" class="inline-flex items-center rounded bg-[#004F9F] px-4 py-2 text-sm font-medium text-white hover:bg-blue-800">
        <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Thêm Sản phẩm
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-4 rounded-md bg-green-50 p-4 text-green-800 border border-green-200">
        @TempData["SuccessMessage"]
    </div>
}

<div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Mã SP</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Tên Sản phẩm (VN)</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Phân loại</th>
                <th class="px-6 py-3 text-center text-xs font-medium uppercase tracking-wider text-gray-500">Trạng thái</th>
                <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Hành động</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">Chưa có sản phẩm nào. Hãy thêm mới!</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr class="hover:bg-gray-50">
                    <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900">@item.Code</td>
                    <td class="px-6 py-4 text-sm text-gray-700">
                        <div class="font-medium text-[#004F9F]">@item.NameVi</div>
                        <div class="text-xs text-gray-500">EN: @item.NameEn</div>
                        @if (item.IsFeatured)
                        {
                            <span class="mt-1 inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">
                                Nổi bật
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500">
                        <div>Khoa: <span class="font-medium">@(item.Category?.NameVi ?? "N/A")</span></div>
                        <div class="text-xs">Hãng: @(item.Brand?.Name ?? "N/A")</div>
                        <div class="text-xs">Loại: @(item.MachineType?.NameVi ?? "N/A")</div>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4 text-center text-sm">
                        @if (item.IsActive)
                        {
                            <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">Hiển thị</span>
                        }
                        else
                        {
                            <span class="inline-flex rounded-full bg-red-100 px-2 text-xs font-semibold leading-5 text-red-800">Đã ẩn</span>
                        }
                    </td>
                    <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-[#004F9F] hover:text-blue-900 font-medium">Sửa</a> |
                        <a href="#" class="text-red-600 hover:text-red-900">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>